---
import Layout from '../components/Layout.astro';
import CalculatorCard from '../components/CalculatorCard.astro';
import SearchBox from '../components/islands/SearchBox.tsx';
import { getCategories, getPopularCalculators, getCalculators, localeCatalog } from '../lib/i18n';

const locale = 'ru';
const categories = getCategories(locale);
const calculators = getCalculators(locale);
const searchData = calculators.map((calculator) => ({
  id: calculator.id,
  name: calculator.name,
  shortDescription: calculator.shortDescription,
  fullPath: calculator.fullPath,
  keywords: calculator.keywords,
  category: calculator.category,
  categoryName: categories.find((category) => category.id === calculator.category)?.name ?? calculator.category,
  popularity: calculator.popularity,
  isNew: calculator.isNew,
}));

const fallbackCalculators = getPopularCalculators(locale);
---

<Layout
  title="Страница не найдена"
  description="К сожалению, такой страницы нет. Вернитесь на главную и продолжите подбор калькулятора."
  noindex
  locale={locale}
>
  <section class="mx-auto max-w-page px-5 sm:px-8 py-16 sm:py-20" data-testid="page-404">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-end border-b border-ink-900 pb-10">
      <div class="lg:col-span-8">
        <div class="font-mono text-sm text-ink-500">/ 404</div>
        <h1 class="mt-3 text-5xl sm:text-6xl font-bold tracking-tightest text-ink-900 leading-none">
          Страница не найдена
        </h1>
        <p class="mt-5 text-ink-500 max-w-2xl text-base sm:text-lg leading-relaxed">
          Возможно, адрес был указан неверно или калькулятор переехал в другую категорию.
          Откройте полный список инструментов или выберите нужный раздел ниже.
        </p>
      </div>
      <div class="lg:col-span-4 lg:text-right">
        <a href={localeCatalog(locale)} class="inline-flex btn-primary" data-testid="page-404-all-link">
          Все калькуляторы
        </a>
        <a
          href="/ru/"
          class="ml-3 inline-flex border border-ink-900 px-5 py-3 text-sm font-medium text-ink-900 hover:bg-ink-900 hover:text-white transition-colors"
          data-testid="page-404-home-link"
        >
          Главная
        </a>
      </div>
    </div>

    <div class="mt-8 border border-ink-900 bg-white p-5 sm:p-6" data-testid="page-404-search">
      <div class="mb-3 flex flex-wrap items-end justify-between gap-3">
        <div>
          <div class="text-xs uppercase tracking-wider text-ink-500">Поиск по сайту</div>
          <h2 class="mt-1 text-2xl font-semibold tracking-tight text-ink-900">
            Найдите нужный калькулятор
          </h2>
        </div>
        <span class="font-mono text-xs text-ink-500">
          {calculators.length} инструментов
        </span>
      </div>
      <SearchBox calculators={searchData} locale={locale} client:load />
    </div>

    <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-5" data-testid="page-404-categories">
      {categories.map((category) => (
        <a
          href={`/${locale}/${category.slug}/`}
          class="border border-ink-200 bg-white p-4 text-sm font-medium text-ink-900 hover:border-ink-900 hover:text-accent transition-colors"
        >
          {category.name}
        </a>
      ))}
    </div>

    <div class="mt-12" data-testid="page-404-popular">
      <div class="mb-5 flex items-end justify-between gap-6">
        <h2 class="text-2xl font-semibold tracking-tight text-ink-900">
          Популярные калькуляторы
        </h2>
        <a
          href={localeCatalog(locale)}
          class="hidden sm:inline-flex text-sm font-medium text-accent underline-offset-4 hover:underline"
        >
          Смотреть все
        </a>
      </div>
      <div class="grid gap-3 sm:gap-4 md:grid-cols-2 lg:grid-cols-3">
        {fallbackCalculators.map((calculator) => (
          <CalculatorCard calc={calculator} locale={locale} />
        ))}
      </div>
    </div>
  </section>
</Layout>
