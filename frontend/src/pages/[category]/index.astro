---
import Layout from '../../components/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import FaqList from '../../components/FaqList.astro';
import { categories, categoriesBySlug } from '../../data/categories';
import { calculatorsByCategory } from '../../data/calculators';
import { SITE } from '../../config/site';

export function getStaticPaths() {
  return categories.map((c) => ({ params: { category: c.slug } }));
}

const { category: slug } = Astro.params;
const category = categoriesBySlug[slug as string];

if (!category) {
  return Astro.redirect('/404');
}

const calcs = calculatorsByCategory(category.id);

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: category.faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const breadcrumbsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: SITE.url + '/' },
    { '@type': 'ListItem', position: 2, name: category.name, item: SITE.url + '/' + category.slug + '/' },
  ],
};
---

<Layout
  title={category.seoTitle}
  description={category.seoDescription}
  jsonLd={[faqJsonLd, breadcrumbsJsonLd]}
>
  <section class="border-b border-ink-900" data-testid={`category-page-${category.slug}`}>
    <div class="mx-auto max-w-page px-5 sm:px-8 pt-10 pb-10">
      <Breadcrumbs items={[
        { label: 'Главная', href: '/' },
        { label: category.name },
      ]} />

      <div class="mt-6 flex items-baseline gap-4 flex-wrap">
        <span class="font-mono text-sm text-ink-500">
          /{category.slug}
        </span>
        <span class="text-xs uppercase tracking-wider text-ink-500">
          {calcs.length} калькуляторов
        </span>
      </div>

      <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tightest text-ink-900 leading-tight" data-testid="category-h1">
        {category.h1}
      </h1>
      <p class="mt-4 max-w-3xl text-base sm:text-lg text-ink-500 leading-relaxed">
        {category.longDescription}
      </p>
    </div>
  </section>

  <section data-testid="category-list">
    <div class="mx-auto max-w-page px-5 sm:px-8 py-12">
      <div class="grid gap-3 sm:gap-4 md:grid-cols-2 lg:grid-cols-3">
        {calcs.map((c) => (
          <CalculatorCard calc={c} showCategory={false} />
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-ink-200">
    <div class="mx-auto max-w-page px-5 sm:px-8 py-12">
      <FaqList items={category.faq} />
    </div>
  </section>
</Layout>
