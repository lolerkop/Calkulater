---
import Layout from '../../components/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FaqList from '../../components/FaqList.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import CalculatorIsland from '../../components/islands/CalculatorIsland.tsx';
import AdPlaceholder from '../../components/AdPlaceholder.astro';
import { categories, categoriesBySlug } from '../../data/categories';
import { calculators, calculatorsById } from '../../data/calculators';
import {
  faqJsonLd,
  breadcrumbsJsonLd,
  webApplicationJsonLd,
  howToJsonLd,
  articleJsonLd,
} from '../../lib/seo';

export function getStaticPaths() {
  return calculators.map((c) => {
    const cat = categories.find((x) => x.id === c.category)!;
    return {
      params: { category: cat.slug, calculator: c.slug },
      props: { calcId: c.id, categorySlug: cat.slug },
    };
  });
}

const { calcId, categorySlug } = Astro.props as { calcId: string; categorySlug: string };
const calc = calculatorsById[calcId];
const category = categoriesBySlug[categorySlug];

const related = (calc.relatedCalculatorIds || [])
  .map((id) => calculatorsById[id])
  .filter(Boolean);

// Базовые схемы: WebApplication + FAQ + Breadcrumbs всегда
const jsonLd: Record<string, unknown>[] = [
  webApplicationJsonLd({
    name: calc.name,
    description: calc.shortDescription,
    path: calc.fullPath,
  }),
  faqJsonLd(calc.faq),
  breadcrumbsJsonLd([
    { label: 'Главная', href: '/' },
    { label: category.name, href: `/${category.slug}/` },
    { label: calc.name, href: calc.fullPath },
  ]),
];

// HowTo — только если у калькулятора есть пошаговая инструкция
if (calc.howToUse && calc.howToUse.length > 0) {
  jsonLd.push(
    howToJsonLd({
      name: calc.name,
      description: calc.shortDescription,
      path: calc.fullPath,
      steps: calc.howToUse,
    }),
  );
}

// Article — собираем тело из «Как считается» и «Пример расчёта»,
// если есть содержательный длинный текст
const articleBody = [calc.longDescription, calc.howItWorks, calc.example]
  .filter(Boolean)
  .join('\n\n');
if (articleBody.length > 0) {
  jsonLd.push(
    articleJsonLd({
      headline: calc.h1 || calc.name,
      description: calc.seoDescription || calc.shortDescription,
      path: calc.fullPath,
      body: articleBody,
    }),
  );
}
---

<Layout
  title={calc.seoTitle}
  description={calc.seoDescription}
  jsonLd={jsonLd}
>
  <section class="border-b border-ink-900" data-testid={`calculator-page-${calc.id}`}>
    <div class="mx-auto max-w-page px-5 sm:px-8 pt-10 pb-8">
      <Breadcrumbs items={[
        { label: 'Главная', href: '/' },
        { label: category.name, href: `/${category.slug}/` },
        { label: calc.name },
      ]} />

      <div class="mt-6 flex items-baseline gap-4 flex-wrap">
        <span class="font-mono text-xs text-ink-500">/{category.slug}/{calc.slug}</span>
      </div>

      <h1 class="mt-2 text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tightest text-ink-900 leading-tight" data-testid="calculator-h1">
        {calc.h1}
      </h1>
      <p class="mt-4 max-w-3xl text-base text-ink-500 leading-relaxed">
        {calc.shortDescription}
      </p>
    </div>
  </section>

  {/* ─── ОСТРОВ КАЛЬКУЛЯТОРА ─── */}
  <section data-testid="calculator-island-wrap">
    <div class="mx-auto max-w-page px-5 sm:px-8 py-10">
      <CalculatorIsland calc={calc} client:load />
    </div>
  </section>

  {/* ─── ОПИСАНИЕ ─── */}
  <section class="border-t border-ink-200 bg-ink-50">
    <div class="mx-auto max-w-page px-5 sm:px-8 py-12 grid lg:grid-cols-2 gap-10 prose-ru">
      <div>
        <h2>О калькуляторе</h2>
        <p>{calc.longDescription}</p>

        {calc.howToUse?.length > 0 && (
          <>
            <h2>Как пользоваться</h2>
            <ol>
              {calc.howToUse.map((s, i) => <li id={`step-${i + 1}`}>{s}</li>)}
            </ol>
          </>
        )}
      </div>

      <div>
        {calc.howItWorks && (
          <>
            <h2>Как считается</h2>
            <p>{calc.howItWorks}</p>
          </>
        )}
        {calc.example && (
          <>
            <h2>Пример расчета</h2>
            <p>{calc.example}</p>
          </>
        )}
      </div>
    </div>
  </section>

  {/* ─── РЕКЛАМНЫЙ ПЛЕЙСХОЛДЕР ─── */}
  <section class="border-t border-ink-200">
    <div class="mx-auto max-w-page px-5 sm:px-8 py-6">
      <AdPlaceholder slot={`calc-${calc.id}-inline`} format="inline" label="Реклама" />
    </div>
  </section>

  {/* ─── FAQ ─── */}
  <section>
    <div class="mx-auto max-w-page px-5 sm:px-8 py-12">
      <FaqList items={calc.faq} />
    </div>
  </section>

  {/* ─── СВЯЗАННЫЕ ─── */}
  {related.length > 0 && (
    <section class="border-t border-ink-200">
      <div class="mx-auto max-w-page px-5 sm:px-8 py-12" data-testid="related-calculators">
        <h2 class="text-2xl font-semibold tracking-tight text-ink-900">Похожие калькуляторы</h2>
        <div class="mt-6 grid gap-3 sm:gap-4 md:grid-cols-2 lg:grid-cols-3">
          {related.map((c) => <CalculatorCard calc={c} />)}
        </div>
      </div>
    </section>
  )}
</Layout>
