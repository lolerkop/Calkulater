---
import Layout from '../components/Layout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import CalculatorCard from '../components/CalculatorCard.astro';
import SearchBox from '../components/islands/SearchBox.tsx';
import { categories } from '../data/categories';
import { calculators, popularCalculators, calculatorsByCategory } from '../data/calculators';
import { SITE } from '../config/site';
import { websiteJsonLd, organizationJsonLd } from '../lib/seo';

const jsonLd = [websiteJsonLd(), organizationJsonLd()];

const searchData = calculators.map((c) => ({
  id: c.id,
  name: c.name,
  shortDescription: c.shortDescription,
  fullPath: c.fullPath,
  keywords: c.keywords,
  category: c.category,
}));
---

<Layout
  title="Онлайн-калькуляторы — финансы, валюты, спорт, ремонт"
  description={SITE.description}
  jsonLd={jsonLd}
>
  {/* ─── HERO ─── */}
  <section class="border-b border-ink-900" data-testid="home-hero">
    <div class="mx-auto max-w-page px-5 sm:px-8 pt-14 pb-12 sm:pt-20 sm:pb-16">
      <div class="grid lg:grid-cols-12 gap-8 items-end">
        <div class="lg:col-span-8">
          <div class="flex items-center gap-3 text-xs uppercase tracking-wider text-ink-500 mb-5">
            <span class="inline-block w-6 h-px bg-ink-900"></span>
            <span>{calculators.length} калькуляторов · {categories.length} категорий</span>
          </div>
          <h1
            class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tightest text-ink-900 leading-[1.05]"
            data-testid="home-h1"
          >
            Онлайн-калькуляторы<br />
            для повседневных <span class="text-accent">расчетов</span>.
          </h1>
          <p class="mt-5 text-base sm:text-lg text-ink-500 max-w-2xl leading-relaxed">
            Финансы, валюты, спорт, ремонт и работа с датами. Все расчеты выполняются в браузере — без регистрации и без отправки данных на сервер.
          </p>
        </div>

        <div class="lg:col-span-4">
          <div class="text-xs uppercase tracking-wider text-ink-500 mb-2">Поиск</div>
          <SearchBox calculators={searchData} client:load />
        </div>
      </div>
    </div>
  </section>

  {/* ─── КАТЕГОРИИ ─── */}
  <section class="border-b border-ink-900" data-testid="home-categories">
    <div class="mx-auto max-w-page px-5 sm:px-8 py-14">
      <div class="flex items-end justify-between mb-8">
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-ink-900">
          Категории
        </h2>
        <span class="font-mono text-xs text-ink-500 hidden sm:block">
          / Все направления расчетов
        </span>
      </div>
      <div class="grid gap-4 sm:gap-5 md:grid-cols-2 lg:grid-cols-3">
        {categories.map((cat, i) => (
          <CategoryCard
            category={cat}
            count={calculatorsByCategory(cat.id).length}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  {/* ─── ПОПУЛЯРНЫЕ ─── */}
  <section data-testid="home-popular">
    <div class="mx-auto max-w-page px-5 sm:px-8 py-14">
      <div class="flex items-end justify-between mb-8">
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-ink-900">
          Популярные калькуляторы
        </h2>
        <span class="font-mono text-xs text-ink-500 hidden sm:block">
          / Самые востребованные инструменты
        </span>
      </div>
      <div class="grid gap-3 sm:gap-4 md:grid-cols-2 lg:grid-cols-3">
        {popularCalculators.map((c) => (
          <CalculatorCard calc={c} />
        ))}
      </div>
    </div>
  </section>

  {/* ─── О ПРОЕКТЕ ─── */}
  <section class="border-t border-ink-200 bg-ink-50" data-testid="home-about">
    <div class="mx-auto max-w-page px-5 sm:px-8 py-14 grid md:grid-cols-3 gap-8">
      <div>
        <div class="text-xs uppercase tracking-wider text-accent mb-2">01</div>
        <h3 class="font-semibold text-ink-900">Без регистрации</h3>
        <p class="mt-2 text-sm text-ink-500 leading-relaxed">
          Не требуем e-mail и не сохраняем введённые данные. Всё работает в вашем браузере.
        </p>
      </div>
      <div>
        <div class="text-xs uppercase tracking-wider text-accent mb-2">02</div>
        <h3 class="font-semibold text-ink-900">Прозрачные формулы</h3>
        <p class="mt-2 text-sm text-ink-500 leading-relaxed">
          У каждого калькулятора есть раздел «Как считается», где описана используемая методика.
        </p>
      </div>
      <div>
        <div class="text-xs uppercase tracking-wider text-accent mb-2">03</div>
        <h3 class="font-semibold text-ink-900">Открытый код</h3>
        <p class="mt-2 text-sm text-ink-500 leading-relaxed">
          Реализация на TypeScript: можно проверить расчеты и предложить улучшения.
        </p>
      </div>
    </div>
  </section>
</Layout>
