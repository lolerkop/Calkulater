---
import Layout from '../components/Layout.astro';
import { localeMeta, ui, getAlternatesForPage, locales } from '../lib/i18n';
import { webPageJsonLd, organizationJsonLd } from '../lib/seo';

const title = 'Online calculators';
const description = 'Choose a language to open free online calculators for finance, currency, fitness, home improvement and dates.';
const alternates = getAlternatesForPage(Object.fromEntries(locales.map((locale) => [locale, `/${locale}/`])));
const jsonLd = [
  organizationJsonLd(),
  webPageJsonLd({
    name: title,
    description,
    path: '/',
    locale: 'en',
  }),
];
---

<Layout
  title={title}
  description={description}
  canonical="/"
  noindex={true}
  locale="en"
  alternates={alternates}
  jsonLd={jsonLd}
>
  <section class="border-b border-ink-900" data-testid="locale-gateway">
    <div class="mx-auto max-w-page px-5 sm:px-8 py-16 sm:py-24">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 text-xs uppercase tracking-wider text-ink-500 mb-5">
          <span class="inline-block h-px w-6 bg-ink-900"></span>
          <span>x-default</span>
        </div>
        <h1 class="text-4xl sm:text-6xl font-bold tracking-tightest text-ink-900 leading-[1.05]">
          Choose your calculator language.
        </h1>
        <p class="mt-5 text-base sm:text-lg text-ink-500 leading-relaxed">
          Open a localized version of the static calculator site. Each language has its own URLs, SEO metadata, FAQ, schema.org and search catalog.
        </p>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {locales.map((locale) => (
          <a
            href={`/${locale}/`}
            class="group border border-ink-900 bg-white p-6 transition-colors hover:bg-ink-900"
            data-testid={`gateway-${locale}`}
            hreflang={localeMeta[locale].htmlLang}
          >
            <div class="font-mono text-xs uppercase tracking-wider text-ink-500 group-hover:text-ink-300">
              {localeMeta[locale].shortLabel}
            </div>
            <h2 class="mt-3 text-2xl font-semibold text-ink-900 group-hover:text-white">
              {localeMeta[locale].label}
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-ink-500 group-hover:text-ink-300">
              {localeMeta[locale].description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
