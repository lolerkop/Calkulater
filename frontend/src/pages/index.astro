---
import Layout from '../components/Layout.astro';
import { localeMeta, ui, getAlternatesForPage, locales } from '../lib/i18n';
import { webPageJsonLd, organizationJsonLd } from '../lib/seo';

const title = 'Online calculators';
const description = 'Choose a language to open free online calculators for finance, currency, fitness, home improvement and dates.';
const alternates = getAlternatesForPage(Object.fromEntries(locales.map((locale) => [locale, `/${locale}/`])));
const jsonLd = [
  organizationJsonLd('en'),
  webPageJsonLd({
    name: title,
    description,
    path: '/',
    locale: 'en',
  }),
];
---

<Layout
  title={title}
  description={description}
  canonical="/"
  noindex={true}
  locale="en"
  alternates={alternates}
  jsonLd={jsonLd}
>
  <section class="hero-mesh border-b border-ink-200" data-testid="locale-gateway">
    <div class="mx-auto max-w-page px-5 sm:px-8 py-16 sm:py-24">
      <div class="max-w-3xl min-w-0">
        <div class="mb-5 flex min-w-0 items-center gap-3 text-xs uppercase tracking-wider text-ink-500">
          <span class="inline-block h-2 w-2 rounded-full bg-sky"></span>
          <span>x-default</span>
        </div>
        <h1 class="text-fit text-4xl font-extrabold leading-[1.05] tracking-[-0.055em] text-ink-900 sm:text-6xl">
          Choose your calculator language.
        </h1>
        <p class="mt-5 text-fit text-base leading-relaxed text-ink-500 sm:text-lg">
          Open a localized version of the static calculator site. Each language has its own URLs, SEO metadata, FAQ, schema.org and search catalog.
        </p>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {locales.map((locale) => (
          <a
            href={`/${locale}/`}
            class="group min-w-0 rounded-3xl border border-white/80 bg-white/85 p-6 shadow-[0_16px_44px_rgba(61,48,133,0.12)] backdrop-blur transition-all hover:-translate-y-1 hover:border-accent-100 hover:shadow-[0_24px_56px_rgba(61,48,133,0.18)]"
            data-testid={`gateway-${locale}`}
            hreflang={localeMeta[locale].htmlLang}
          >
            <div class="font-mono text-fit text-xs uppercase tracking-wider text-accent">
              {localeMeta[locale].shortLabel}
            </div>
            <h2 class="mt-3 text-fit text-2xl font-bold text-ink-900 group-hover:text-accent">
              {localeMeta[locale].label}
            </h2>
            <p class="mt-2 text-fit text-sm leading-relaxed text-ink-500">
              {localeMeta[locale].description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
