    breadcrumbs: 'Migas de pan',
  },
  de: {
    title: 'Über das Projekt',
    description: 'Über die Online-Rechner: Berechnungen im Browser, Datenschutz und Ergebnisse als Orientierung.',
    p1: 'Diese Website sammelt praktische Online-Rechner für Finanzen, Währungen, Fitness, Heimwerken und Daten. Berechnungen laufen im Browser.',
    p2: 'Ergebnisse sind Orientierungsschätzungen. Prüfe bei finanziellen, steuerlichen, medizinischen und baulichen Entscheidungen Eingaben und offizielle Quellen.',
    breadcrumbs: 'Breadcrumbs',
  },
  fr: {
    title: 'À propos du projet',
