---
import Layout from '../../components/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getAlternatesForPage, isLocale, localeHome, locales, ui, type Locale } from '../../lib/i18n';
import { breadcrumbsJsonLd, webPageJsonLd } from '../../lib/seo';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const locale = (Astro.props.locale ?? 'ru') as Locale;
if (!isLocale(locale)) return Astro.redirect('/404');
const copy = ui[locale];
const path = `/${locale}/about/`;
const pageCopy: Record<Locale, { title: string; description: string; p1: string; p2: string; breadcrumbs: string }> = {
