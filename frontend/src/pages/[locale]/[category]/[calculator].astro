      `Porovnajte niekoľko scenárov pre ${name}, kým sa rozhodnete.`,
      'Skontrolujte, ako sa výsledok zmení pri úprave jednej hodnoty.',
      'Zdieľajte vyplnený odkaz, ak potrebujete čísla s niekým prebrať.',
    ],
    checklist: [
      'Pred použitím výsledku skontrolujte všetky jednotky.',
      'Používajte výsledok ako orientačný odhad, nie ako finálne odborné rozhodnutie.',
      'Overte oficiálne sadzby, rozmery produktov alebo podmienky, ak ovplyvňujú výpočet.',
    ],
    mistakes: [
      'Miešanie jednotiek alebo mien v jednom výpočte.',
      'Zabudnutie rezervy, poplatkov alebo miestnych pravidiel mimo vzorca.',
      'Použitie zaokrúhleného odhadu ako finálnej zmluvnej hodnoty.',
    ],
  },
  hu: {
    breadcrumbs: 'Morzsanavigáció',
    nav: 'Kalkulátor navigáció',
    formula: 'Képlet és logika',
    example: 'Példa',
    freshness: 'Aktualitás',
    demoRates: 'demo árfolyamok',
    formulaBased: 'képlet alapján',
    currencyNote: 'A valutaárfolyamok ebben az MVP-ben demonstrációs értékek. Pénzváltás előtt ellenőrizze az aktuális árfolyamot.',
    formulaNote: 'A számítás stabil képleteket és az űrlapban megadott értékeket használ.',
    useCases: (name: string) => [
      `Hasonlítson össze több forgatókönyvet a ${name} használatával döntés előtt.`,
      'Nézze meg, hogyan változik az eredmény egyetlen érték módosításakor.',
      'Ossza meg a kitöltött linket, ha másokkal is egyeztetné a számokat.',
    ],
    checklist: [
      'Az eredmény használata előtt ellenőrizze az összes mértékegységet.',
      'Az eredményt tájékoztató becslésként használja, ne végleges szakmai döntésként.',
      'Ellenőrizze a hivatalos árfolyamokat, termékméreteket vagy feltételeket, ha befolyásolják a számítást.',
    ],
    mistakes: [
      'Mértékegységek vagy pénznemek keverése egy számításban.',
      'Tartalék, díjak vagy helyi szabályok figyelmen kívül hagyása, amelyek nem részei a képletnek.',
      'Kerekített becslés használata végleges szerződéses értékként.',
    ],
  },
}[locale];
const related = (calc.relatedCalculatorIds || [])
  .map((id) => getCalculatorById(id, locale))
  .filter(Boolean);
const categoryFallback = getCalculatorsByCategory(calc.category, locale)
  .filter((item) => item.id !== calc.id)
  .sort((a, b) => b.popularity - a.popularity || a.name.localeCompare(b.name, locale))
  .slice(0, 3);
const relatedOrCategory = related.length > 0 ? related : categoryFallback;
const ruGuidance = calculatorGuidance(calc);
const guidance = locale === 'ru'
  ? ruGuidance
  : {
      useCases: pageCopy.useCases(calc.name.toLowerCase()),
      checklist: pageCopy.checklist,
      mistakes: pageCopy.mistakes,
    };
const ruFreshness = calculatorFreshness(calc);
const freshness = locale === 'ru'
  ? ruFreshness
  : {
      label: pageCopy.freshness,
      value: calc.category === 'currency' ? pageCopy.demoRates : pageCopy.formulaBased,
      note: calc.category === 'currency'
        ? pageCopy.currencyNote
        : pageCopy.formulaNote,
    };
const fallbackTips = [...guidance.checklist, ...guidance.mistakes].join(' ');
const seoContent = calc.seoContent ?? {
  intro: calc.longDescription,
  howItWorks: calc.howItWorks,
  example: calc.example,
  tips: fallbackTips,
  faq: calc.faq,
};
const seoFaq = seoContent.faq.length > 0 ? seoContent.faq : calc.faq;
const articleBody = [
  seoContent.intro,
  seoContent.howItWorks,
  seoContent.example,
  seoContent.tips,
].join('\n\n');

const pageAnchors = [
  { href: '#calculator', label: copy.calculation },
  { href: '#details', label: copy.details },
  { href: '#usage', label: copy.tips },
  { href: '#faq', label: 'FAQ' },
  ...(relatedOrCategory.length > 0 ? [{ href: '#related', label: copy.related }] : []),
];

const alternates = getAlternatesForCalculator(calc.id);
const jsonLd = [
  webPageJsonLd({
    name: calc.h1 || calc.name,
    description: calc.seoDescription || calc.shortDescription,
    path: calc.fullPath,
    locale,
  }),
  webApplicationJsonLd({
    name: calc.name,
    description: calc.shortDescription,
    path: calc.fullPath,
    locale,
  }),
  faqJsonLd(seoFaq),
  breadcrumbsJsonLd([
    { label: copy.home, href: localeHome(locale) },
    { label: category.name, href: `/${locale}/${category.slug}/` },
    { label: calc.name, href: calc.fullPath },
  ]),
  howToJsonLd({
    name: calc.name,
    description: calc.shortDescription,
    path: calc.fullPath,
    steps: calc.howToUse,
    locale,
  }),
  articleJsonLd({
    headline: calc.h1 || calc.name,
    description: calc.seoDescription || calc.shortDescription,
    path: calc.fullPath,
    locale,
    body: articleBody,
  }),
];
const islandCalc = {
  id: calc.id,
  name: calc.name,
  fields: calc.fields,
  disclaimer: calc.disclaimer,
};
---

<Layout
  title={calc.seoTitle}
  description={calc.seoDescription}
  canonical={calc.fullPath}
  ogType="article"
  locale={locale}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <section class="border-b border-ink-900" data-testid={`calculator-page-${calc.id}`}>
    <div class="mx-auto max-w-page px-5 pb-7 pt-8 sm:px-8 sm:pb-8 sm:pt-10">
      <Breadcrumbs
        label={pageCopy.breadcrumbs}
        items={[
          { label: copy.home, href: localeHome(locale) },
          { label: category.name, href: `/${locale}/${category.slug}/` },
          { label: calc.name },
        ]}
      />

      <div class="mt-5 flex min-w-0 flex-wrap items-baseline gap-3 sm:mt-6 sm:gap-4">
        <span class="font-mono text-fit text-xs text-ink-500">/{locale}/{category.slug}/{calc.slug}</span>
      </div>

      <h1 class="mt-2 text-fit text-2xl font-bold leading-tight tracking-tightest text-ink-900 sm:text-4xl lg:text-5xl" data-testid="calculator-h1">
        {calc.h1}
      </h1>
      <p class="mt-4 max-w-3xl text-fit text-base leading-relaxed text-ink-500">
        {calc.shortDescription}
      </p>

      <div class="mt-6 grid grid-cols-2 gap-2 sm:mt-7 sm:gap-3 lg:grid-cols-4" data-testid="calculator-meta">
        <div class="min-w-0 border border-ink-200 bg-white p-3 sm:p-4">
          <div class="text-fit text-[10px] uppercase tracking-wider text-ink-500">{copy.category}</div>
          <a href={`/${locale}/${category.slug}/`} class="mt-1 block text-fit text-sm font-medium text-ink-900 hover:text-accent">
            {category.name}
          </a>
        </div>
        <div class="min-w-0 border border-ink-200 bg-white p-3 sm:p-4">
          <div class="text-fit text-[10px] uppercase tracking-wider text-ink-500">{copy.fields}</div>
          <div class="mt-1 font-mono text-sm text-ink-900">{calc.fields.length}</div>
        </div>
        <div class="min-w-0 border border-ink-200 bg-white p-3 sm:p-4">
          <div class="text-[10px] uppercase tracking-wider text-ink-500">FAQ</div>
          <div class="mt-1 font-mono text-fit text-sm text-ink-900">{seoFaq.length} {copy.faqQuestions}</div>
        </div>
        <div class="min-w-0 border border-ink-200 bg-white p-3 sm:p-4" data-testid="calculator-freshness">
          <div class="text-fit text-[10px] uppercase tracking-wider text-ink-500">{freshness.label}</div>
          <div class="mt-1 text-fit text-sm font-medium text-ink-900">{freshness.value}</div>
        </div>
      </div>

      <nav class="-mx-5 mt-5 flex gap-2 overflow-x-auto px-5 pb-1 sm:mx-0 sm:mt-6 sm:flex-wrap sm:overflow-visible sm:px-0 sm:pb-0" aria-label={pageCopy.nav} data-testid="calculator-anchor-nav">
        {pageAnchors.map((item) => (
          <a href={item.href} class="max-w-[12rem] shrink-0 border border-ink-200 bg-white px-3 py-2 text-fit text-sm leading-tight text-ink-800 transition-colors hover:border-ink-900 hover:text-accent sm:max-w-full">
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <section id="calculator" class="border-b border-ink-900">
    <div class="mx-auto max-w-page px-5 py-8 sm:px-8 sm:py-12">
      <CalculatorIsland calc={islandCalc} locale={locale} client:load />
    </div>
  </section>

  <section id="details" class="border-b border-ink-900" data-testid="calculator-details">
    <div class="mx-auto grid max-w-page min-w-0 gap-6 px-5 py-8 sm:gap-8 sm:px-8 sm:py-12 lg:grid-cols-3">
      <div class="min-w-0 lg:col-span-2">
        <h2 class="text-fit text-2xl font-semibold tracking-tight text-ink-900 sm:text-3xl">{copy.details}</h2>
        <p class="mt-4 text-fit text-base leading-relaxed text-ink-600">{seoContent.intro}</p>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <div class="min-w-0 border border-ink-200 bg-white p-5">
            <h3 class="text-fit font-semibold text-ink-900">{pageCopy.formula}</h3>
            <p class="mt-2 text-fit text-sm leading-relaxed text-ink-600">{seoContent.howItWorks}</p>
          </div>
          <div class="min-w-0 border border-ink-200 bg-white p-5">
            <h3 class="text-fit font-semibold text-ink-900">{pageCopy.example}</h3>
            <p class="mt-2 text-fit text-sm leading-relaxed text-ink-600">{seoContent.example}</p>
          </div>
        </div>
      </div>
      <aside>
        <AdPlaceholder />
      </aside>
    </div>
  </section>

  <section id="usage" class="border-b border-ink-900" data-testid="calculator-usage">
    <div class="mx-auto max-w-page px-5 py-8 sm:px-8 sm:py-12">
      <div class="mb-6 max-w-3xl">
        <h2 class="text-fit text-2xl font-semibold tracking-tight text-ink-900 sm:text-3xl">{copy.tips}</h2>
        <p class="mt-4 text-fit text-base leading-relaxed text-ink-600">{seoContent.tips}</p>
      </div>
      <div class="grid gap-4 lg:grid-cols-3">
        <div class="min-w-0 border border-ink-200 bg-white p-5" data-testid="calculator-use-cases">
          <h2 class="text-fit text-lg font-semibold text-ink-900">{copy.useCases}</h2>
          <ul class="mt-3 space-y-2 text-fit text-sm leading-relaxed text-ink-600">
            {guidance.useCases.map((item) => <li>— {item}</li>)}
          </ul>
        </div>
        <div class="min-w-0 border border-ink-200 bg-white p-5" data-testid="calculator-checklist">
          <h2 class="text-fit text-lg font-semibold text-ink-900">{copy.checklist}</h2>
          <ul class="mt-3 space-y-2 text-fit text-sm leading-relaxed text-ink-600">
            {guidance.checklist.map((item) => <li>— {item}</li>)}
          </ul>
        </div>
        <div class="min-w-0 border border-ink-200 bg-white p-5" data-testid="calculator-common-mistakes">
          <h2 class="text-fit text-lg font-semibold text-ink-900">{copy.mistakes}</h2>
          <ul class="mt-3 space-y-2 text-fit text-sm leading-relaxed text-ink-600">
            {guidance.mistakes.map((item) => <li>— {item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="border-b border-ink-900" data-testid="calculator-faq">
    <div class="mx-auto max-w-page px-5 py-8 sm:px-8 sm:py-12">
      <h2 class="mb-6 text-fit text-2xl font-semibold tracking-tight text-ink-900 sm:text-3xl">FAQ</h2>
      <FaqList items={seoFaq} />
    </div>
  </section>

  {relatedOrCategory.length > 0 && (
    <section id="related" data-testid="related-calculators">
      <div class="mx-auto max-w-page px-5 py-8 sm:px-8 sm:py-12">
        <div class="mb-6 flex min-w-0 items-end justify-between gap-6 sm:mb-8">
          <h2 class="min-w-0 text-fit text-2xl font-semibold tracking-tight text-ink-900 sm:text-3xl">
            {related.length > 0 ? copy.related : `${copy.similarInCategory} ${category.name}`}
          </h2>
          <a href={`/${locale}/${category.slug}/`} class="shrink-0 text-fit text-sm font-medium text-accent underline-offset-4 hover:underline">
            {category.name}
          </a>
        </div>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {relatedOrCategory.map((item) => (
            <CalculatorCard calc={item} locale={locale} />
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
