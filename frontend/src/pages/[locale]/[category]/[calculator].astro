import {
  findCalculatorBySlug,
  getAlternatesForCalculator,
  getCalculatorById,
  getCalculatorsByCategory,
  getCategories,
  isLocale,
  localeHome,
  locales,
  ui,
  type Locale,
} from '../../../lib/i18n';
import {
  articleJsonLd,
  breadcrumbsJsonLd,
  faqJsonLd,
  howToJsonLd,
  webApplicationJsonLd,
  webPageJsonLd,
} from '../../../lib/seo';
import { calculatorGuidance } from '../../../lib/calculatorGuidance';
import { calculatorFreshness } from '../../../lib/calculatorFreshness';

export function getStaticPaths() {
  return locales.flatMap((locale) =>
    getCategories(locale).flatMap((category) =>
      getCalculatorsByCategory(category.id, locale).map((calculator) => ({
        params: { locale, category: category.slug, calculator: calculator.slug },
        props: { locale, categorySlug: category.slug, calculatorSlug: calculator.slug },
      })),
    ),
  );
}

const locale = (Astro.props.locale ?? 'ru') as Locale;
if (!isLocale(locale)) return Astro.redirect('/404');
const { categorySlug, calculatorSlug } = Astro.props as { categorySlug: string; calculatorSlug: string };
const found = findCalculatorBySlug(locale, categorySlug, calculatorSlug);
if (!found) return Astro.redirect('/404');

