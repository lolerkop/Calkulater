---
import Layout from '../../../components/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CalculatorCard from '../../../components/CalculatorCard.astro';
import FaqList from '../../../components/FaqList.astro';
import {
  getAlternatesForCategory,
  getCalculatorsByCategory,
  getCategories,
  getCategoriesBySlug,
  isLocale,
  localeCatalog,
  localeHome,
  locales,
  ui,
  type Locale,
} from '../../../lib/i18n';
import {
  breadcrumbsJsonLd,
  collectionPageJsonLd,
  faqJsonLd,
  itemListJsonLd,
} from '../../../lib/seo';

export function getStaticPaths() {
  return locales.flatMap((locale) =>
    getCategories(locale).map((category) => ({
      params: { locale, category: category.slug },
      props: { locale, categorySlug: category.slug },
    })),
  );
}

const locale = (Astro.props.locale ?? 'ru') as Locale;
if (!isLocale(locale)) return Astro.redirect('/404');
const { categorySlug } = Astro.props as { categorySlug: string };
const copy = ui[locale];
const pageCopy = {
  ru: { breadcrumbs: 'Хлебные крошки' },
  en: { breadcrumbs: 'Breadcrumbs' },
  es: { breadcrumbs: 'Migas de pan' },
  de: { breadcrumbs: 'Breadcrumbs' },
  fr: { breadcrumbs: 'Fil d’Ariane' },
  pt: { breadcrumbs: 'Navegação estrutural' },
  it: { breadcrumbs: 'Breadcrumb' },
  pl: { breadcrumbs: 'Nawigacja okruszkowa' },
  nl: { breadcrumbs: 'Kruimelpad' },
  ro: { breadcrumbs: 'Breadcrumb' },
  id: { breadcrumbs: 'Breadcrumb' },
  tr: { breadcrumbs: 'Breadcrumb' },
  vi: { breadcrumbs: 'Breadcrumb' },
  cs: { breadcrumbs: 'Drobečková navigace' },
  uk: { breadcrumbs: 'Навігаційний ланцюжок' },
  sk: { breadcrumbs: 'Omrvinková navigácia' },
  hu: { breadcrumbs: 'Morzsanavigáció' },
}[locale];
const category = getCategoriesBySlug(locale)[categorySlug];
if (!category) return Astro.redirect('/404');

const calculators = getCalculatorsByCategory(category.id, locale);
const popularInCategory = calculators
  .slice()
  .sort((a, b) => b.popularity - a.popularity)
  .slice(0, 3);
const newInCategory = calculators
  .filter((calculator) => calculator.isNew)
  .sort((a, b) => b.popularity - a.popularity || a.name.localeCompare(b.name, locale));
const otherCategories = getCategories(locale).filter((item) => item.id !== category.id);
const keywordChips = Array.from(
  new Set(calculators.flatMap((calculator) => calculator.keywords.slice(0, 2))),
).slice(0, 8);
const calculatorItems = calculators.map((calculator) => ({
  name: calculator.name,
  description: calculator.shortDescription,
  path: calculator.fullPath,
}));
const categoryPath = `/${locale}/${category.slug}/`;
const alternates = getAlternatesForCategory(category.id);

const jsonLd = [
  collectionPageJsonLd({
    name: category.h1,
    description: category.seoDescription,
    path: categoryPath,
    items: calculatorItems,
    locale,
  }),
  itemListJsonLd({
    name: `${category.name}: ${copy.allCalculators}`,
    path: categoryPath,
    items: calculatorItems,
  }),
  faqJsonLd(category.faq),
  breadcrumbsJsonLd([
    { label: copy.home, href: localeHome(locale) },
    { label: category.name, href: categoryPath },
  ]),
];
---

<Layout
  title={category.seoTitle}
  description={category.seoDescription}
  canonical={categoryPath}
  locale={locale}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <section class="border-b border-ink-900" data-testid={`category-page-${category.slug}`}>
    <div class="mx-auto max-w-page px-5 pb-8 pt-8 sm:px-8 sm:pb-10 sm:pt-10">
      <Breadcrumbs
        label={pageCopy.breadcrumbs}
        items={[
          { label: copy.home, href: localeHome(locale) },
          { label: category.name },
        ]}
      />

      <div class="mt-5 flex min-w-0 flex-wrap items-baseline gap-3 sm:mt-6 sm:gap-4">
        <span class="font-mono text-fit text-sm text-ink-500">/{locale}/{category.slug}</span>
        <span class="text-fit text-xs uppercase tracking-wider text-ink-500">
          {calculators.length} {copy.instruments}
        </span>
      </div>

      <h1 class="mt-3 text-fit text-3xl font-bold leading-tight tracking-tightest text-ink-900 sm:text-5xl" data-testid="category-h1">
        {category.h1}
      </h1>
      <p class="mt-3 max-w-3xl text-fit text-base leading-relaxed text-ink-500 sm:mt-4 sm:text-lg">
        {category.longDescription}
      </p>

      <div class="mt-6 grid grid-cols-2 gap-2 sm:mt-8 sm:gap-3 lg:grid-cols-4" data-testid="category-hero-stats">
        <div class="min-w-0 border border-ink-200 bg-white p-3 sm:p-4">
          <div class="font-mono text-2xl font-semibold text-ink-900">{calculators.length}</div>
          <div class="mt-1 text-fit text-xs uppercase tracking-wider text-ink-500">{copy.instruments}</div>
        </div>
        <div class="min-w-0 border border-ink-200 bg-white p-3 sm:p-4">
          <div class="font-mono text-2xl font-semibold text-ink-900">{popularInCategory.length}</div>
          <div class="mt-1 text-fit text-xs uppercase tracking-wider text-ink-500">{copy.quickStart}</div>
        </div>
        <div class="min-w-0 border border-ink-200 bg-white p-3 sm:p-4">
          <div class="font-mono text-2xl font-semibold text-ink-900">{newInCategory.length}</div>
          <div class="mt-1 text-fit text-xs uppercase tracking-wider text-ink-500">{copy.newest}</div>
        </div>
        <div class="min-w-0 border border-ink-200 bg-white p-3 sm:p-4">
          <div class="font-mono text-2xl font-semibold text-ink-900">{category.faq.length}</div>
          <div class="mt-1 text-xs uppercase tracking-wider text-ink-500">FAQ</div>
        </div>
      </div>

      <div class="mt-6 flex flex-wrap gap-2" data-testid="category-quick-links">
        {popularInCategory.map((calculator) => (
          <a href={calculator.fullPath} class="max-w-full border border-ink-900 bg-white px-3 py-2 text-fit text-sm font-medium leading-tight text-ink-900 transition-colors hover:bg-ink-900 hover:text-white">
            {calculator.name}
          </a>
        ))}
        <a href="#all-calculators" class="max-w-full border border-ink-200 px-3 py-2 text-fit text-sm font-medium leading-tight text-ink-700 transition-colors hover:border-ink-900 hover:text-accent">
          {copy.allInSection}
        </a>
      </div>
    </div>
  </section>

  <section id="all-calculators" data-testid="category-list">
    <div class="mx-auto max-w-page px-5 py-8 sm:px-8 sm:py-12">
      <div class="mb-6 flex min-w-0 items-end justify-between gap-6 sm:mb-8">
        <h2 class="min-w-0 text-fit text-2xl font-semibold tracking-tight text-ink-900 sm:text-3xl">{copy.allInSection}</h2>
        <a href={localeCatalog(locale)} class="shrink-0 text-sm font-medium text-accent underline-offset-4 hover:underline">
          {copy.allCalculators}
        </a>
      </div>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {calculators.map((calculator) => (
          <CalculatorCard calc={calculator} showCategory={false} locale={locale} />
        ))}
      </div>
    </div>
  </section>

  {keywordChips.length > 0 && (
    <section class="border-t border-ink-900" data-testid="category-keywords">
      <div class="mx-auto max-w-page px-5 py-8 sm:px-8 sm:py-10">
        <div class="flex flex-wrap gap-2">
          {keywordChips.map((keyword) => (
            <span class="max-w-full border border-ink-200 bg-white px-3 py-2 text-fit text-xs text-ink-500">{keyword}</span>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="border-t border-ink-900" data-testid="category-faq">
    <div class="mx-auto max-w-page px-5 py-8 sm:px-8 sm:py-12">
      <h2 class="mb-6 text-fit text-2xl font-semibold tracking-tight text-ink-900">FAQ</h2>
      <FaqList items={category.faq} />
    </div>
  </section>

  <section class="border-t border-ink-900" data-testid="category-other">
    <div class="mx-auto max-w-page px-5 py-8 sm:px-8 sm:py-12">
      <h2 class="mb-6 text-fit text-2xl font-semibold tracking-tight text-ink-900">{copy.categories}</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {otherCategories.map((item) => (
          <a href={`/${locale}/${item.slug}/`} class="min-w-0 border border-ink-200 bg-white p-4 transition-colors hover:border-ink-900 hover:bg-ink-50">
            <div class="text-fit font-medium text-ink-900">{item.name}</div>
            <p class="mt-1 line-clamp-3 text-fit text-xs leading-relaxed text-ink-500">{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
