  },
  ro: {
    title: 'Politica de confidentialitate',
    description: 'Cum site-ul de calculatoare online gestioneaza datele introduse si calculele in browser.',
    p1: 'Valorile introduse in formulare sunt folosite pentru calcule in browser. Nu salvam datele din formulare si nu cerem inregistrare.',
    p2: 'Daca ulterior vor fi adaugate instrumente de analiza sau publicitate, functionarea lor va fi descrisa separat in aceasta politica.',
    breadcrumbs: 'Breadcrumb',
  },
  id: {
    title: 'Kebijakan privasi',
    description: 'Bagaimana situs kalkulator online menangani input dan perhitungan di browser.',
    p1: 'Nilai yang dimasukkan ke formulir digunakan untuk perhitungan di browser. Kami tidak menyimpan input formulir dan tidak meminta pendaftaran.',
    p2: 'Jika alat analitik atau iklan ditambahkan nanti, cara kerjanya akan dijelaskan terpisah dalam kebijakan ini.',
    breadcrumbs: 'Breadcrumb',
  },
  tr: {
    title: 'Gizlilik politikası',
    description: 'Online hesaplayıcı sitesinin girilen verileri ve tarayıcıdaki hesaplamaları nasıl ele aldığı.',
    p1: 'Formlara girilen değerler tarayıcıdaki hesaplamalar için kullanılır. Form girdilerini saklamayız ve kayıt istemeyiz.',
    p2: 'Analitik veya reklam araçları daha sonra eklenirse, çalışma biçimleri bu politikada ayrıca açıklanacaktır.',
    breadcrumbs: 'Breadcrumb',
  },
  vi: {
    title: 'Chính sách quyền riêng tư',
    description: 'Cách trang máy tính online xử lý dữ liệu nhập và phép tính trong trình duyệt.',
    p1: 'Các giá trị nhập vào biểu mẫu được dùng cho phép tính trong trình duyệt. Chúng tôi không lưu dữ liệu biểu mẫu và không yêu cầu đăng ký.',
    p2: 'Nếu sau này thêm công cụ phân tích hoặc quảng cáo, cách hoạt động của chúng sẽ được mô tả riêng trong chính sách này.',
    breadcrumbs: 'Breadcrumb',
  },
  cs: {
    title: 'Zásady ochrany soukromí',
    description: 'Jak web online kalkulaček pracuje se zadanými hodnotami a výpočty v prohlížeči.',
    p1: 'Hodnoty zadané do formulářů se používají pro výpočty v prohlížeči. Neukládáme vstupy z formulářů a nevyžadujeme registraci.',
    p2: 'Pokud později přidáme analytiku nebo reklamu, jejich fungování bude popsáno samostatně v těchto zásadách.',
    breadcrumbs: 'Drobečková navigace',
  },
  uk: {
    title: 'Політика конфіденційності',
    description: 'Як сайт онлайн-калькуляторів працює з введеними даними та розрахунками в браузері.',
    p1: 'Введені у форми значення використовуються лише для розрахунків у браузері. Вони не надсилаються на сервер і не зберігаються автоматично в localStorage.',
    p2: 'Параметри додаються до URL лише після явного натискання «Скопіювати посилання». Таке посилання містить введені значення, тому передавайте його лише людям, яким довіряєте.',
    breadcrumbs: 'Навігаційний ланцюжок',
  },
  sk: {
    title: 'Zásady ochrany súkromia',
    description: 'Ako web online kalkulačiek pracuje so zadanými hodnotami a výpočtami v prehliadači.',
    p1: 'Hodnoty zadané do formulárov sa používajú na výpočty v prehliadači. Neukladáme vstupy z formulárov a nevyžadujeme registráciu.',
    p2: 'Ak neskôr pridáme analytiku alebo reklamu, ich fungovanie bude opísané samostatne v týchto zásadách.',
    breadcrumbs: 'Omrvinková navigácia',
  },
  hu: {
    title: 'Adatvédelmi irányelvek',
    description: 'Hogyan kezeli az online kalkulátoroldal a megadott értékeket és a böngészőben futó számításokat.',
    p1: 'Az űrlapokba írt értékeket a böngészőben futó számítások használják. Az űrlapadatokat nem mentjük, és nem kérünk regisztrációt.',
    p2: 'Ha később analitika vagy reklám kerül az oldalra, annak működését külön leírjuk ezekben az irányelvekben.',
    breadcrumbs: 'Morzsanavigáció',
  },
};
const { title, description } = pageCopy[locale];
const alternates = getAlternatesForPage(Object.fromEntries(locales.map((locale) => [locale, `/${locale}/privacy/`])));
const jsonLd = [
  webPageJsonLd({ name: title, description, path, locale }),
  breadcrumbsJsonLd([
    { label: copy.home, href: localeHome(locale) },
    { label: title, href: path },
  ]),
];
---

<Layout title={title} description={description} canonical={path} locale={locale} alternates={alternates} jsonLd={jsonLd}>
  <section class="hero-mesh border-b border-ink-200" data-testid="privacy-page">
    <div class="mx-auto max-w-page min-w-0 px-5 py-10 sm:px-8 sm:py-16">
      <Breadcrumbs label={pageCopy[locale].breadcrumbs} items={[{ label: copy.home, href: localeHome(locale) }, { label: title }]} />
      <h1 class="mt-5 text-fit text-4xl font-extrabold tracking-[-0.05em] text-ink-900 sm:mt-6 sm:text-5xl">{title}</h1>
      <div class="mt-6 max-w-3xl space-y-4 rounded-3xl border border-white/80 bg-white/80 p-5 text-fit text-base leading-relaxed text-ink-600 shadow-lg backdrop-blur sm:p-7">
        <p>{pageCopy[locale].p1}</p>
        <p>{pageCopy[locale].p2}</p>
      </div>
    </div>
  </section>
</Layout>
