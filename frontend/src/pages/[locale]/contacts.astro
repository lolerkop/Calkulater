    lead: 'Bir hesaplama hatası bulduysanız, yeni bir hesaplayıcı önermek istiyorsanız veya sayfa verilerini netleştirmek gerekiyorsa yazın.',
    emptyEmail: 'Genel lansmandan önce iletişim adresi eklenecek.',
    breadcrumbs: 'Breadcrumb',
  },
  vi: {
    title: 'Liên hệ',
    description: 'Liên hệ cho câu hỏi, lỗi tính toán và đề xuất máy tính mới.',
    lead: 'Hãy viết nếu bạn thấy lỗi tính toán, muốn đề xuất máy tính mới hoặc cần làm rõ dữ liệu trên trang.',
    emptyEmail: 'Địa chỉ liên hệ sẽ được thêm trước khi ra mắt công khai.',
    breadcrumbs: 'Breadcrumb',
  },
  cs: {
    title: 'Kontakt',
    description: 'Kontakt pro otázky, chyby výpočtů a návrhy nových kalkulaček.',
    lead: 'Napište, pokud jste našli chybu ve výpočtu, chcete navrhnout novou kalkulačku nebo potřebujete upřesnit data na stránce.',
    emptyEmail: 'Kontaktní email bude doplněn před veřejným spuštěním.',
    breadcrumbs: 'Drobečková navigace',
  },
  uk: {
    title: 'Контакти',
    description: 'Контакти для запитань, помилок розрахунків і пропозицій нових калькуляторів.',
    lead: 'Напишіть, якщо знайшли помилку в розрахунку, хочете запропонувати новий калькулятор або уточнити дані на сторінці.',
    emptyEmail: 'Контактний email буде додано перед публічним запуском.',
    breadcrumbs: 'Навігаційний ланцюжок',
  },
  sk: {
    title: 'Kontakt pre slovenské Kalkulačky',
    description: 'Kontakt pre otázky, chyby výpočtov a návrhy nových kalkulačiek.',
    lead: 'Napíšte, ak ste našli chybu vo výpočte, chcete navrhnúť novú kalkulačku alebo potrebujete upresniť dáta na stránke.',
    emptyEmail: 'Kontaktný email bude doplnený pred verejným spustením.',
    breadcrumbs: 'Omrvinková navigácia',
  },
  hu: {
    title: 'Kapcsolat',
    description: 'Kapcsolat kérdésekhez, számítási hibákhoz és új kalkulátorjavaslatokhoz.',
    lead: 'Írjon, ha számítási hibát talált, új kalkulátort javasolna, vagy pontosítaná az oldalon szereplő adatokat.',
    emptyEmail: 'A kapcsolati email cím a nyilvános indulás előtt kerül hozzáadásra.',
    breadcrumbs: 'Morzsanavigáció',
  },
};
const { title, description } = pageCopy[locale];
const alternates = getAlternatesForPage(Object.fromEntries(locales.map((locale) => [locale, `/${locale}/contacts/`])));
const jsonLd = [
  webPageJsonLd({ name: title, description, path, type: 'ContactPage', locale }),
  breadcrumbsJsonLd([
    { label: copy.home, href: localeHome(locale) },
    { label: title, href: path },
  ]),
];
const email = SITE.email;
---

<Layout title={title} description={description} canonical={path} locale={locale} alternates={alternates} jsonLd={jsonLd}>
  <section class="border-b border-ink-900" data-testid="contacts-page">
    <div class="mx-auto max-w-page min-w-0 px-5 py-8 sm:px-8 sm:py-12">
      <Breadcrumbs label={pageCopy[locale].breadcrumbs} items={[{ label: copy.home, href: localeHome(locale) }, { label: title }]} />
      <h1 class="mt-5 text-fit text-3xl font-bold tracking-tightest text-ink-900 sm:mt-6 sm:text-5xl">{title}</h1>
      <p class="mt-6 max-w-2xl text-fit text-base leading-relaxed text-ink-600">
        {pageCopy[locale].lead}
      </p>
      {email ? (
        <a href={`mailto:${email}`} class="mt-6 inline-flex max-w-full border border-ink-900 bg-ink-900 px-4 py-3 text-center text-fit text-sm font-semibold leading-tight text-white transition-colors hover:bg-white hover:text-ink-900">
          {email}
        </a>
      ) : (
        <p class="mt-6 inline-flex max-w-full border border-ink-200 bg-white px-4 py-3 text-fit text-sm font-semibold leading-tight text-ink-700">
          {pageCopy[locale].emptyEmail}
        </p>
      )}
    </div>
  </section>
</Layout>
