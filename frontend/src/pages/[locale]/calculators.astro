---
import Layout from '../../components/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import CalculatorCatalog from '../../components/islands/CalculatorCatalog';
import {
  getAlternatesForPage,
  getCalculators,
  getCategories,
  isLocale,
  localeCatalog,
  localeHome,
  locales,
  ui,
  type Locale,
} from '../../lib/i18n';
import {
  breadcrumbsJsonLd,
  collectionPageJsonLd,
  itemListJsonLd,
} from '../../lib/seo';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const locale = (Astro.props.locale ?? 'ru') as Locale;
if (!isLocale(locale)) return Astro.redirect('/404');

const copy = ui[locale];
const pageCopy = {
  ru: { breadcrumbs: 'Хлебные крошки' },
  en: { breadcrumbs: 'Breadcrumbs' },
  es: { breadcrumbs: 'Migas de pan' },
  de: { breadcrumbs: 'Breadcrumbs' },
  fr: { breadcrumbs: 'Fil d’Ariane' },
  pt: { breadcrumbs: 'Navegação estrutural' },
  it: { breadcrumbs: 'Breadcrumb' },
  pl: { breadcrumbs: 'Nawigacja okruszkowa' },
  nl: { breadcrumbs: 'Kruimelpad' },
  ro: { breadcrumbs: 'Breadcrumb' },
  id: { breadcrumbs: 'Breadcrumb' },
  tr: { breadcrumbs: 'Breadcrumb' },
  vi: { breadcrumbs: 'Breadcrumb' },
  cs: { breadcrumbs: 'Drobečková navigace' },
  uk: { breadcrumbs: 'Навігаційний ланцюжок' },
  sk: { breadcrumbs: 'Omrvinková navigácia' },
  hu: { breadcrumbs: 'Morzsanavigáció' },
}[locale];
const calculators = getCalculators(locale);
const categories = getCategories(locale);
const title = copy.catalogTitle;
const description = copy.catalogDescription;
const catalogPath = localeCatalog(locale);
const alternates = getAlternatesForPage(Object.fromEntries(locales.map((locale) => [locale, `/${locale}/calculators/`])));

const items = calculators.map((calculator) => ({
  name: calculator.name,
  description: calculator.shortDescription,
  path: calculator.fullPath,
}));

const grouped = categories.map((category) => ({
  category,
  calculators: calculators
    .filter((calculator) => calculator.category === category.id)
    .sort((a, b) => b.popularity - a.popularity),
}));

const catalogCalculators = calculators.map((calculator) => {
  const category = categories.find((item) => item.id === calculator.category);
  return {
    id: calculator.id,
    name: calculator.name,
    shortDescription: calculator.shortDescription,
    fullPath: calculator.fullPath,
    keywords: calculator.keywords,
    category: calculator.category,
    categoryName: category?.name,
    popularity: calculator.popularity,
    isNew: calculator.isNew,
  };
});

const catalogCategories = categories.map((category) => ({
  id: category.id,
  name: category.name,
  slug: category.slug,
}));

const jsonLd = [
  collectionPageJsonLd({
    name: title,
    description,
    path: catalogPath,
    items,
    locale,
  }),
  itemListJsonLd({
    name: title,
    path: catalogPath,
    items,
  }),
  breadcrumbsJsonLd([
    { label: copy.home, href: localeHome(locale) },
    { label: title, href: catalogPath },
  ]),
];
---

<Layout
  title={title}
  description={description}
  canonical={catalogPath}
  locale={locale}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <section class="border-b border-ink-900" data-testid="calculators-page">
    <div class="mx-auto max-w-page px-5 sm:px-8 pt-10 pb-10">
      <Breadcrumbs
        label={pageCopy.breadcrumbs}
        items={[
          { label: copy.home, href: localeHome(locale) },
          { label: copy.allCalculators },
        ]}
      />

      <div class="mt-6 flex min-w-0 flex-wrap items-baseline gap-4">
        <span class="font-mono text-fit text-sm text-ink-500">/{locale}/calculators</span>
        <span class="text-fit text-xs uppercase tracking-wider text-ink-500">
          {calculators.length} {copy.instruments}
        </span>
      </div>

      <h1 class="mt-3 text-fit text-4xl font-bold leading-tight tracking-tightest text-ink-900 sm:text-5xl">
        {title}
      </h1>
      <p class="mt-4 max-w-3xl text-fit text-base leading-relaxed text-ink-500 sm:text-lg">
        {copy.catalogLead}
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-page px-5 sm:px-8 py-12 space-y-12">
      <CalculatorCatalog
        calculators={catalogCalculators}
        categories={catalogCategories}
        locale={locale}
        client:load
      />

      <noscript>
        <div class="space-y-12">
          {grouped.map(({ category, calculators: categoryCalculators }) => (
            <section data-testid={`calculators-group-${category.slug}`}>
              <div class="flex min-w-0 items-end justify-between gap-6 border-b border-ink-200 pb-4">
                <div class="min-w-0">
                  <div class="font-mono text-fit text-xs text-ink-500">/{category.slug}</div>
                  <h2 class="mt-1 text-fit text-2xl font-semibold tracking-tight text-ink-900">
                    {category.name}
                  </h2>
                </div>
                <a href={`/${locale}/${category.slug}/`} class="hidden shrink-0 text-sm font-medium text-accent underline-offset-4 hover:underline sm:inline-flex">
                  {copy.openCategory}
                </a>
              </div>

              <div class="mt-5 grid gap-3 sm:gap-4 md:grid-cols-2 lg:grid-cols-3">
                {categoryCalculators.map((calculator) => (
                  <CalculatorCard calc={calculator} showCategory={false} locale={locale} />
                ))}
              </div>
            </section>
          ))}
        </div>
      </noscript>
    </div>
  </section>
</Layout>
