---
import {
  getCategories,
  localeCatalog,
  localeHome,
  localeMeta,
  locales,
  ui,
  type AlternateLink,
  type Locale,
} from '../lib/i18n';

interface Props {
  locale?: Locale;
  alternates?: AlternateLink[];
}

const { locale = 'ru', alternates = [] } = Astro.props;
const categories = getCategories(locale);
const copy = ui[locale];
const meta = localeMeta[locale];
const currentPath = Astro.url.pathname;
const catalogPath = localeCatalog(locale);
const isAllActive = currentPath.startsWith(catalogPath);
const languageLinks = alternates.filter((item): item is AlternateLink & { locale: Locale } =>
  item.locale !== 'x-default' && locales.includes(item.locale),
);
const navLabel = {
  ru: 'Основная навигация',
  en: 'Main navigation',
  es: 'Navegación principal',
  de: 'Hauptnavigation',
  fr: 'Navigation principale',
  pt: 'Navegação principal',
  it: 'Navigazione principale',
  pl: 'Nawigacja glowna',
  nl: 'Hoofdnavigatie',
  ro: 'Navigare principala',
  id: 'Navigasi utama',
  tr: 'Ana gezinme',
  vi: 'Điều hướng chính',
  cs: 'Hlavní navigace',
  uk: 'Основна навігація',
  sk: 'Hlavná navigácia',
  hu: 'Fő navigáció',
}[locale];
---

<header class="sticky top-0 z-40 border-b border-ink-200 bg-white/85 backdrop-blur-xl" data-testid="site-header">
  <div class="mx-auto max-w-page px-4 sm:px-8">
    <div class="flex min-h-16 items-center justify-between gap-4 py-3">
      <a
        href={localeHome(locale)}
        class="group flex shrink-0 items-center gap-2.5"
        aria-label={`${meta.siteName} - ${copy.home}`}
        data-testid="header-logo-link"
      >
        <span class="brand-mark" aria-hidden="true">C</span>
        <span class="text-lg font-extrabold tracking-[-0.035em] text-ink-900 text-fit sm:text-xl">
          {meta.siteName}
        </span>
      </a>

      <nav
        class="hidden min-w-0 flex-1 items-center justify-end gap-1.5 overflow-x-auto md:flex"
        aria-label={navLabel}
        data-testid="header-nav"
      >
        <a
          href={catalogPath}
          class:list={[
            'site-nav-link font-semibold',
            isAllActive ? 'bg-accent-50 text-accent' : 'text-ink-700',
          ]}
          aria-current={isAllActive ? 'page' : undefined}
          data-testid="header-nav-all-calculators"
        >
          {copy.allCalculators}
        </a>
        {categories.map((c) => {
          const categoryPath = `/${locale}/${c.slug}/`;
          const isActive = currentPath.startsWith(categoryPath);
          const currentState = isActive
            ? (currentPath === categoryPath ? 'page' : 'location')
            : undefined;
          return (
            <a
              href={categoryPath}
              class:list={[
                'site-nav-link font-medium',
                isActive ? 'bg-accent-50 font-semibold text-accent' : 'text-ink-600',
              ]}
              aria-current={currentState}
              data-testid={`header-nav-${c.slug}`}
            >
              {c.name}
            </a>
          );
        })}
        {languageLinks.length > 1 && (
          <span class="ml-2 flex max-w-[280px] shrink-0 items-center gap-1 overflow-x-auto rounded-xl border border-ink-200 bg-ink-50 p-1">
            {languageLinks.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'shrink-0 rounded-lg px-2 py-1.5 text-xs font-semibold transition-colors hover:text-accent',
                  item.locale === locale ? 'bg-white text-accent shadow-sm' : 'text-ink-500',
                ]}
                hreflang={localeMeta[item.locale].htmlLang}
                data-testid={`header-lang-${item.locale}`}
              >
                {localeMeta[item.locale].shortLabel}
              </a>
            ))}
          </span>
        )}
      </nav>
    </div>

    {/* Мобильная навигация — горизонтальная прокрутка */}
    <nav
      class="mobile-scroll -mx-4 flex items-center gap-2 overflow-x-auto border-t border-ink-100 px-4 py-2.5 text-sm md:hidden"
      aria-label={navLabel}
      data-testid="header-nav-mobile"
    >
      <a
        href={catalogPath}
        class:list={[
          'shrink-0 whitespace-nowrap rounded-lg px-3 py-1.5 font-semibold hover:bg-accent-50 hover:text-accent',
          isAllActive ? 'bg-accent-50 text-accent' : 'text-ink-700',
        ]}
        aria-current={isAllActive ? 'page' : undefined}
        data-testid="header-nav-mobile-all-calculators"
      >
        {copy.all}
      </a>
      {categories.map((c) => {
        const categoryPath = `/${locale}/${c.slug}/`;
        const isActive = currentPath.startsWith(categoryPath);
        const currentState = isActive
          ? (currentPath === categoryPath ? 'page' : 'location')
          : undefined;
        return (
          <a
            href={categoryPath}
            class:list={[
              'shrink-0 whitespace-nowrap rounded-lg px-3 py-1.5 hover:bg-accent-50 hover:text-accent',
              isActive ? 'bg-accent-50 font-semibold text-accent' : 'text-ink-600',
            ]}
            aria-current={currentState}
            data-testid={`header-nav-mobile-${c.slug}`}
          >
            {c.name}
          </a>
        );
      })}
      {languageLinks.map((item) => (
        <a
          href={item.href}
          class:list={[
            'shrink-0 whitespace-nowrap rounded-lg border border-ink-200 px-2.5 py-1 font-semibold hover:text-accent',
            item.locale === locale ? 'border-accent-100 bg-accent-50 text-accent' : 'bg-white text-ink-600',
          ]}
          hreflang={localeMeta[item.locale].htmlLang}
          data-testid={`header-nav-mobile-lang-${item.locale}`}
        >
          {localeMeta[item.locale].shortLabel}
        </a>
      ))}
    </nav>
  </div>
</header>
