---
import type { CalculatorDef } from '../lib/types';
import { getCategoryById, ui, type Locale } from '../lib/i18n';

interface Props {
  calc: CalculatorDef;
  showCategory?: boolean;
  locale?: Locale;
}

const { calc, showCategory = true, locale = 'ru' } = Astro.props;
const category = getCategoryById(calc.category, locale);
const copy = ui[locale];
const isPopular = calc.popularity >= 80;
const isNew = calc.isNew === true;
---

<a
  href={calc.fullPath}
  class="group flex min-h-[176px] min-w-0 flex-col overflow-hidden border border-ink-200 bg-white p-4 transition-colors hover:border-ink-900 hover:bg-ink-50 hover:shadow-[3px_3px_0_0_rgba(10,10,10,0.05)] sm:min-h-[190px] sm:p-5"
  data-testid={`calculator-card-${calc.slug}`}
>
  <div class="flex min-w-0 items-start justify-between gap-3">
    {showCategory ? (
      <span class="min-w-0 text-[10px] uppercase tracking-wider text-ink-500 text-fit">
        {category?.name}
      </span>
    ) : (
      <span class="min-w-0 font-mono text-[10px] uppercase tracking-wider text-ink-400 text-fit">
        /{calc.slug}
      </span>
    )}
    <span class="flex shrink-0 flex-wrap justify-end gap-1.5">
      {isNew ? (
        <span
          class="border border-ink-900 bg-ink-900 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-white"
          data-testid="calculator-card-new"
        >
          {copy.newBadge}
        </span>
      ) : null}
      {isPopular ? (
        <span
          class="border border-accent px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-accent"
          data-testid="calculator-card-popular"
        >
          {copy.popularBadge}
        </span>
      ) : null}
    </span>
  </div>

  <h3 class="mt-3 text-base font-semibold text-ink-900 group-hover:text-accent transition-colors leading-snug text-fit">
    {calc.name}
  </h3>
  <p class="mt-2 text-sm text-ink-500 leading-relaxed line-clamp-2">
    {calc.shortDescription}
  </p>

  <div class="mt-auto flex items-center justify-between gap-4 border-t border-ink-200 pt-4">
    <span class="min-w-0 text-sm font-medium text-accent text-fit">
      {copy.open}
    </span>
    <span
      aria-hidden="true"
      class="inline-flex h-7 w-7 items-center justify-center border border-ink-900 text-ink-900 transition-colors group-hover:bg-ink-900 group-hover:text-white"
    >
      →
    </span>
  </div>
</a>
