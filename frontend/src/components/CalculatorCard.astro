---
import type { CalculatorDef } from '../lib/types';
import { getCategoryById, ui, type Locale } from '../lib/i18n';

interface Props {
  calc: CalculatorDef;
  showCategory?: boolean;
  locale?: Locale;
}

const { calc, showCategory = true, locale = 'ru' } = Astro.props;
const category = getCategoryById(calc.category, locale);
const copy = ui[locale];
const isPopular = calc.popularity >= 80;
const isNew = calc.isNew === true;
---

<a
  href={calc.fullPath}
  class="calculator-card-shell group flex flex-col"
  data-testid={`calculator-card-${calc.slug}`}
>
  <div class="flex min-w-0 items-start justify-between gap-3">
    {showCategory ? (
      <span class="min-w-0 text-[10px] uppercase tracking-wider text-ink-500 text-fit">
        {category?.name}
      </span>
    ) : (
      <span class="min-w-0 font-mono text-[10px] uppercase tracking-wider text-ink-400 text-fit">
        /{calc.slug}
      </span>
    )}
    <span class="flex shrink-0 flex-wrap justify-end gap-1.5">
      {isNew ? (
        <span
          class="rounded-full bg-ink-900 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider text-white"
          data-testid="calculator-card-new"
        >
          {copy.newBadge}
        </span>
      ) : null}
      {isPopular ? (
        <span
          class="rounded-full bg-accent-50 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider text-accent"
          data-testid="calculator-card-popular"
        >
          {copy.popularBadge}
        </span>
      ) : null}
    </span>
  </div>

  <h3 class="mt-3 text-lg font-bold leading-snug tracking-[-0.02em] text-ink-900 transition-colors group-hover:text-accent text-fit">
    {calc.name}
  </h3>
  <p class="mt-2 text-sm text-ink-500 leading-relaxed line-clamp-2">
    {calc.shortDescription}
  </p>

  <div class="mt-auto flex items-center justify-between gap-4 border-t border-ink-100 pt-4">
    <span class="min-w-0 text-sm font-medium text-accent text-fit">
      {copy.open}
    </span>
    <span
      aria-hidden="true"
      class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-accent-50 text-accent transition-all group-hover:translate-x-0.5 group-hover:bg-accent group-hover:text-white"
    >
      →
    </span>
  </div>
</a>
