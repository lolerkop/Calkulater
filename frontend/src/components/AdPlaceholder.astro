---
// Placeholder for future ad slots. It is hidden by default so the MVP does not
// show empty ad boxes before monetization is connected.

interface Props {
  slot: string;
  label?: string;
  className?: string;
  format?: 'banner' | 'square' | 'inline';
}

const {
  slot = 'main',
  label = 'Рекламный блок',
  className = '',
  format = 'banner',
} = Astro.props;

const formatClasses: Record<string, string> = {
  banner: 'h-24 sm:h-28',
  square: 'h-64 max-w-sm',
  inline: 'h-20',
};

const shouldRender = import.meta.env.PUBLIC_SHOW_AD_PLACEHOLDERS === 'true';
---

{shouldRender && (
  <aside
    class:list={[
      'w-full min-w-0 border border-dashed border-ink-300 bg-ink-50 text-ink-500',
      'flex items-center justify-center text-center text-xs uppercase tracking-wider',
      formatClasses[format],
      className,
    ]}
    data-testid={`ad-placeholder-${slot}`}
    data-ad-slot={slot}
    aria-label={label}
    role="complementary"
  >
    <span class="font-mono text-fit px-3">
      {label} · {slot}
    </span>
  </aside>
)}
