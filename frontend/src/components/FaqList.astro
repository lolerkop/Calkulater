---
import type { FaqItem } from '../lib/types';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="space-y-3" data-testid="faq-section">
    {items.map((item, i) => (
      <details
        class="faq-item group"
        data-testid={`faq-item-${i}`}
      >
        <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-base font-semibold text-ink-900">
          <span class="min-w-0 text-fit">{item.q}</span>
          <span
            class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-accent-50 font-mono text-lg leading-none text-accent transition-transform group-open:rotate-45"
            aria-hidden="true"
          >+</span>
        </summary>
        <p class="mt-3 text-sm text-ink-500 leading-relaxed">{item.a}</p>
      </details>
    ))}
</div>
