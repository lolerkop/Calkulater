---
import { SITE } from '../config/site';
import { localeMeta, type AlternateLink, type Locale } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  locale?: Locale;
  alternates?: AlternateLink[];
}

const {
  title,
  description,
  canonical,
  ogImage = SITE.ogImage,
  ogType = 'website',
  noindex = false,
  jsonLd,
  locale = 'ru',
  alternates = [],
} = Astro.props;
const meta = localeMeta[locale];

const url = canonical
  ? new URL(canonical, SITE.url).toString()
  : new URL(Astro.url.pathname, SITE.url).toString();
const ogImageAbs = ogImage?.startsWith('http')
  ? ogImage
  : new URL(ogImage ?? '/og-default.png', SITE.url).toString();

const fullTitle = title.includes(meta.siteName) ? title : `${title} — ${meta.siteName}`;
const safeDescription = description.trim();
const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

function serializeJsonLd(data: Record<string, unknown>): string {
  return JSON.stringify(data)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026')
    .replace(/\u2028/g, '\\u2028')
    .replace(/\u2029/g, '\\u2029');
}
---

<title>{fullTitle}</title>
<meta name="description" content={safeDescription} />
{!noindex && <link rel="canonical" href={url} />}
{alternates.map((item) => (
  <link
    rel="alternate"
    hreflang={item.locale === 'x-default' ? 'x-default' : localeMeta[item.locale].htmlLang}
    href={new URL(item.href, SITE.url).toString()}
  />
))}
<meta
  name="robots"
  content={noindex
    ? 'noindex,nofollow'
    : 'index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1'}
/>

<meta property="og:type" content={ogType} />
<meta property="og:locale" content={meta.ogLocale} />
<meta property="og:site_name" content={meta.siteName} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={safeDescription} />
<meta property="og:url" content={url} />
<meta property="og:image" content={ogImageAbs} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${meta.siteName}: online calculators`} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={safeDescription} />
<meta name="twitter:image" content={ogImageAbs} />

{jsonLdItems.map((data) => (
  <script type="application/ld+json" set:html={serializeJsonLd(data)} />
))}
