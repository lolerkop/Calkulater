---
import type { CalculatorDef, Category } from '../lib/types';
import { ui, type Locale } from '../lib/i18n';

interface Props {
  category: Category;
  count: number;
  index: number;
  featuredCalculators?: Pick<CalculatorDef, 'name' | 'fullPath'>[];
  locale?: Locale;
}

const { category, count, index, featuredCalculators = [], locale = 'ru' } = Astro.props;
const copy = ui[locale];
const categoryCardCopy = {
  ru: { countLabel: 'калк.', inside: 'Внутри раздела' },
  en: { countLabel: 'tools', inside: 'Inside' },
  es: { countLabel: 'herr.', inside: 'Dentro' },
  de: { countLabel: 'Tools', inside: 'Im Bereich' },
  fr: { countLabel: 'outils', inside: 'Dans la section' },
  pt: { countLabel: 'ferr.', inside: 'Na secção' },
  it: { countLabel: 'strumenti', inside: 'Nella sezione' },
  pl: { countLabel: 'narz.', inside: 'W sekcji' },
  nl: { countLabel: 'tools', inside: 'In deze sectie' },
  ro: { countLabel: 'calc.', inside: 'In sectiune' },
  id: { countLabel: 'alat', inside: 'Di bagian ini' },
  tr: { countLabel: 'araç', inside: 'Bu bölümde' },
  vi: { countLabel: 'công cụ', inside: 'Trong mục này' },
  cs: { countLabel: 'nástrojů', inside: 'V této sekci' },
  uk: { countLabel: 'інстр.', inside: 'У цьому розділі' },
  sk: { countLabel: 'nástrojov', inside: 'V tejto sekcii' },
  hu: { countLabel: 'eszköz', inside: 'Ebben a részben' },
}[locale];
const num = String(index + 1).padStart(2, '0');
const featured = featuredCalculators.slice(0, 3);
---

<a
  href={`/${locale}/${category.slug}/`}
  class="group flex min-h-[204px] min-w-0 flex-col overflow-hidden border border-ink-900 bg-white p-4 transition-colors hover:bg-ink-900 sm:min-h-[260px] sm:p-6"
  data-testid={`category-card-${category.slug}`}
>
  <div class="flex min-w-0 items-start justify-between gap-3">
    <span class="font-mono text-xs text-ink-500 group-hover:text-ink-300">{num}</span>
    <span class="min-w-0 text-xs uppercase tracking-wider text-ink-500 group-hover:text-ink-300 text-fit">
      {count} {categoryCardCopy.countLabel}
    </span>
  </div>
  <h3 class="mt-4 text-xl font-semibold text-ink-900 group-hover:text-white transition-colors text-fit sm:mt-6">
    {category.name}
  </h3>
  <p class="mt-2 text-sm text-ink-500 group-hover:text-ink-300 leading-relaxed line-clamp-3">
    {category.description}
  </p>

  {featured.length > 0 ? (
    <div class="mt-5 hidden border-t border-ink-200 pt-4 group-hover:border-ink-700 sm:block" data-testid="category-card-featured">
      <div class="text-[10px] uppercase tracking-wider text-ink-400 group-hover:text-ink-300">
        {categoryCardCopy.inside}
      </div>
      <ul class="mt-2 space-y-1.5">
        {featured.map((calc) => (
          <li class="flex items-center gap-2 text-xs text-ink-600 group-hover:text-ink-200">
            <span aria-hidden="true" class="font-mono text-ink-400 group-hover:text-ink-300">/</span>
            <span class="min-w-0 line-clamp-2 text-fit">{calc.name}</span>
          </li>
        ))}
      </ul>
    </div>
  ) : null}

  <div class="mt-auto flex min-w-0 items-center gap-2 pt-4 text-sm font-medium text-accent sm:pt-6">
    <span class="min-w-0 text-fit">
    {copy.open}
    </span>
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
  </div>
</a>
