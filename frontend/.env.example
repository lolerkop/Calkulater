# Required for production SEO URLs. Leave empty locally to use http://localhost:3000.
PUBLIC_SITE_URL=

# Optional contact email for service pages.
PUBLIC_CONTACT_EMAIL=

# Optional analytics IDs. Leave empty to render no analytics scripts.
PUBLIC_GA_ID=
PUBLIC_YM_ID=

# Optional visual placeholders for future ad slots. Use true only while preparing ads.
PUBLIC_SHOW_AD_PLACEHOLDERS=
